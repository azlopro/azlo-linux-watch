# azlo-linux-watch configuration
# Set your Discord webhook URL below, then start the service:
#   sudo systemctl start azlo-linux-watch
DISCORD_WEBHOOK_URL=

# Comma-separated list of enabled features:
#   authlog  — tail /var/log/auth.log for failed logins, sudo, su, SSH keys
#   geoip    — enrich source IPs with country/city/ISP via ip-api.com
#   pam      — receive instant login/logout events via PAM hook
#   who      — poll `who -u` every 5s for login/logout detection
#   ebpf     — trace process spawns via eBPF (requires kernel ≥ 5.x)
FEATURES=authlog,geoip,pam,who,ebpf

# Set to "false" to disable IP geolocation enrichment
GEOIP_ENABLED=true
